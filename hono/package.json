{
  "name": "hono",
  "type": "module",
  "scripts": {
    "build": "esbuild --bundle --outfile=./dist/index.js --platform=node --target=node20 --format=esm ./src/lambda.ts",
    "zip": "zip -j lambda.zip dist/index.js",
    "update": "aws lambda update-function-code --zip-file fileb://lambda.zip --function-name hello --region us-east-1",
    "publish": "aws lambda publish-version --function-name hello --region us-east-1",
    "deploy": "run-s build zip update publish",
    "dev": "tsx watch src/dev.ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "esbuild": "^0.21.4",
    "npm-run-all2": "^6.2.0",
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@better-auth/mongo-adapter": "^1.6.10",
    "@better-auth/oauth-provider": "^1.6.10",
    "@hono/node-server": "^2.0.2",
    "better-auth": "^1.6.10",
    "dotenv": "^17.4.2",
    "hono": "^4.12.18",
    "mongodb": "^7.2.0",
    "zod": "^4.4.3"
  }
}
